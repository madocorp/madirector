<Root>

  <Panel name="search">
    <PanelTitle>search</PanelTitle>
    <PanelContent>
      <Label>Pattern:
        <Input name="pattern" />
      </Label>
      <CheckBox name="caseSensitive" value="true">Case sensitive</CheckBox>
      <CheckBox name="regexp">Regexp</CheckBox>
      <ButtonBox>
        <Button hotKey="ESCAPE" onPress="MADIR\Screen\Controller::closeSearchPanel">Cancel</Button><Space />
        <Button hotKey="RETURN" onPress="MADIR\Screen\Controller::search">Search</Button>
      </ButtonBox>
    </PanelContent>
  </Panel>

</Root>